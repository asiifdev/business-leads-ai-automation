# ============================================================
# Prospex — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://prospex:yourpassword@localhost:5432/prospex"
POSTGRES_USER=prospex
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=prospex

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=changeme

# AI Provider (OpenAI or compatible: OpenRouter, Ollama, etc.)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional: custom base URL for OpenRouter/Ollama
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://localhost:11434/v1

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Production only
# HTTP_PORT=80
# HTTPS_PORT=443
