# ============================================================
# Prospex — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Required ─────────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://prospex:yourpassword@localhost:5432/prospex"

# JWT signing secret — min 16 chars, use: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── Database container (used by docker-compose) ───────────────
POSTGRES_USER=prospex
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=prospex

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
# For production (set in docker-compose.prod.yml):
# REDIS_PASSWORD=changeme
# REDIS_URL="redis://:changeme@localhost:6379"

# ── AI Provider ───────────────────────────────────────────────
# OpenAI, OpenRouter, Ollama, or any OpenAI-compatible provider
# Leave empty to use built-in mock content (no API cost)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Uncomment to use alternative providers:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://localhost:11434/v1

# ── App URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Production only ───────────────────────────────────────────
# APP_URL=https://yourdomain.com
# API_URL=https://yourdomain.com
# HTTP_PORT=80
# HTTPS_PORT=443
